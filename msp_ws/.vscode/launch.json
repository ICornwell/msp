{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "compounds": [
        {
            "name": "MSP Front & Back",
            "configurations": [
                "Run Service Hub",
                "Run Data Hub",
                "Run Actor-Work",
                "Front End",
                "Launch Chrome",
                "Attach to Chrome",
            ],
            "stopAll": true
        }
    ],
    "configurations": [
        {
            "command": "yarn build:all",
            "name": "Just Build Everything",
            "request": "launch",
            "type": "node-terminal",
            "cwd": "${workspaceFolder}/.."
        },
        {
            "command": "yarn build:aftercommons",
            "name": "Just Build Services",
            "request": "launch",
            "type": "node-terminal",
            "cwd": "${workspaceFolder}/.."
        },
        {
            "command": "yarn fes:start",
            "name": "Front End",
            "request": "launch",
            "type": "node-terminal",
            "cwd": "${workspaceFolder}/.."
        },
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/../msp_fes/src/ui",
            "runtimeArgs": [
                "--remote-debugging-port=9222"
            ],
            "sourceMaps": true
        },
        {
            "name": "Attach to Chrome",
            "port": 9222,
            "request": "attach",
            "type": "chrome",
            "webRoot": "${workspaceFolder}/../msp_fes/dist"
        },
        {
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["servicehub:start"],
            "name": "Run Service Hub",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}/..",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/../msp_servicehub/distApi/**/*.js"
            ]
        },
        {
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["datahub:start"],
            "name": "Run Data Hub",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}/..",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/../msp_datahub/distApi/**/*.js"
            ]
        },
        {
             
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["actorwork:start"],
            "name": "Run Actor-Work",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}/..",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/../msp_actorwork/distApi/**/*.js"
            ]
        }
    ]
}