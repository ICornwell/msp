{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "compounds": [
        {
            "name": "MSP Front & Back",
            "configurations": [
                "Run Service Hub",
                "Run Data Hub",
                "Run Security",
                "Run Semaphores",
                "Run Actor-Work",
                "Run Front End",
                "Launch Chrome",
                "Attach to Chrome",
            ],
            "stopAll": true
        },
        {
            "name": "MSP Data",
            "configurations": [
                "BusData Run 'dgm_bus_intg'",
                "TechData Run 'docgraph'",
            ],
            "stopAll": true
        },
        {
         "name": "MSP Front & Back & Data",
            "configurations": [
                "BusData Run 'dgm_bus_intg'",
                "TechData Run 'docgraph'",
                "Run Service Hub",
                "Run Data Hub",
                "Run Security",
                "Run Semaphores",
                "Run Actor-Work",
                "Run AWS",
                "Run Front End",
                "Launch Chrome",
                "Attach to Chrome",
            ],
            "stopAll": true
        }
    ],
    "configurations": [
        {
            "command": "yarn build:all",
            "name": "Just Build Everything",
            "request": "launch",
            "type": "node-terminal",
            "cwd": "${workspaceFolder}/.."
        },
        {
            "command": "yarn build:aftercommons",
            "name": "Just Build Services",
            "request": "launch",
            "type": "node-terminal",
            "cwd": "${workspaceFolder}/.."
        },
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/../msp_fes/src/ui",
            "runtimeArgs": [
                "--remote-debugging-port=9222"
            ],
            "sourceMaps": true
        },
        {
            "name": "Attach to Chrome",
            "port": 9222,
            "request": "attach",
            "type": "chrome",
            "webRoot": "${workspaceFolder}/../msp_fes/dist"
        },
        {
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["servicehub:start"],
            "name": "Run Service Hub",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}/..",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/../msp_servicehub/distApi/**/*.js"
            ]
        },
        {
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["datahub:start"],
            "name": "Run Data Hub",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}/..",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/../msp_datahub/distApi/**/*.js"
            ]
        },
        {
             
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["actorwork:start"],
            "name": "Run Actor-Work",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}/..",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/../msp_actorwork/distApi/**/*.js"
            ]
        },
         {
             
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["aws:start"],
            "name": "Run AWS",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}/..",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/../msp_aws/distApi/**/*.js"
            ]
        },
        {
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["fes:start"],
            "name": "Run Front End",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}/..",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/../msp_fes/distApi/**/*.js"
            ]

        },
        {
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["security:start"],
            "name": "Run Security",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}/..",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/../msp_fes/distApi/**/*.js"
            ]

        },
        {
            "runtimeExecutable": "yarn",
            "runtimeArgs": ["semaphores:start"],
            "name": "Run Semaphores",
            "request": "launch",
            "type": "node",
            "cwd": "${workspaceFolder}/..",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/../msp_fes/distApi/**/*.js"
            ]

        },
         {
            "type": "lldb",
            "request": "launch",
            "name": "TechData Run 'docgraph'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=docgraph",
                    "--package=docgraph",
                    "--manifest-path=../msp_tech_data/Cargo.toml"
                ],
                "filter": {
                    "name": "docgraph",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}/../msp_tech_data"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "TechData Test 'docgraph'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=docgraph",
                    "--package=docgraph",
                    "--manifest-path=../msp_tech_data/Cargo.toml"
                ],
                "filter": {
                    "name": "docgraph",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}/../msp_tech_data"
        },
         {
            "name": "BusData Run 'dgm_bus_intg'",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "cwd": "${workspaceFolder}/../msp_bus_data/src/dgm_bus_intg",
            "program": "${workspaceFolder}/../msp_bus_data/src/dgm_bus_intg/service.go"
        }
    ]
}