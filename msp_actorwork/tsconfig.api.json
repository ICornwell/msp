{
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "nodenext",
    "skipLibCheck": true,

    "declaration": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./distApi",
  //  "declarationDir": "./dist/types",
    "esModuleInterop": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    /* Bundler mode */
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": false,
    "experimentalDecorators": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": false,


  },
  "include": ["src/serviceActivityElements/**/*.ts", "./src/manifest/**/*.ts",
    "./src/apiElements/**/*.ts", "./src/uiElements/fluxorObjects/**/*.ts"]
}
