      "forceEsmInServe": false
    },
    {
      "package": "@emotion/react",
      "module": "./emotionReact",
      "factory": "emotionReactExportCode",
      "forceEsmInServe": false
    },
    {
      "package": "@emotion/styled",
      "module": "./emotionStyled",
      "factory": "emotionStyledExportCode",
      "forceEsmInServe": false
    }
  ]
}