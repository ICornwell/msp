{
  "name": "@module-federation/vite",
  "version": "1.9.1",
  "description": "Vite plugin for Module Federation",
  "type": "module",
  "source": "src/index.ts",
  "main": "./lib/index.cjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*"
  ],
  "scripts": {
    "prepare": "husky install",
    "generate:shared-esm-registry": "node ./scripts/generate-shared-esm-exports-registry.mjs",
    "generate:factory-files": "tsx ./scripts/generate-factory-files.ts",
    "generate:factory-files:dry": "tsx ./scripts/generate-factory-files.ts --dry-run",
    "audit:shared-esm-exports": "node ./src/esmExportEnumerator/index.mjs",
    "audit:shared-esm-exports:write": "node ./src/esmExportEnumerator/index.mjs --write",
    "audit:shared-esm-exports:check": "node ./src/esmExportEnumerator/index.mjs --check",
    "fmt": "prettier --write src",
    "fmt.check": "prettier --check src",
    "format": "pretty-quick",
    "dev": "microbundle watch --no-sourcemap --compress=false",
    "prebuild": "echo 'pre build mf update' && tsx ./scripts/generate-factory-files.ts -- 'msp_ui_common/uiLib/behaviours' 'msp_ui_common/uiLib/contexts' 'msp_ui_common/uiLib' && echo \"rebuild manifest\" && node ./scripts/generate-shared-esm-exports-registry.mjs",
    "build": "node ./scripts/generate-shared-esm-exports-registry.mjs && rimraf lib && microbundle --no-sourcemap --compress=false",
    "dev-rv": "pnpm -filter 'examples-rust-vite*' run dev",
    "preview-rv": "pnpm -filter 'examples-rust-vite*' run preview",
    "dev-vv": "pnpm -filter 'examples-vite-vite*' run dev",
    "dev-nv": "pnpm -filter 'examples-nuxt-vite-host' -filter 'examples-vite-vite-remote' run dev",
    "preview-vv": "pnpm -filter 'examples-vite-vite*'  run preview",
    "multi-example": "pnpm --filter \"multi-example-*\" --parallel run start",
    "test": "vitest",
    "e2e": "playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/module-federation/vite.git"
  },
  "keywords": [
    "vite",
    "module federation",
    "microfrontend"
  ],
  "author": {
    "name": "Giorgio Boa",
    "email": "giorgiob.boa@gmail.com",
    "url": "https://github.com/gioboa"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/module-federation/vite/issues"
  },
  "homepage": "https://github.com/module-federation/vite#readme",
  "packageManager": "pnpm@9.1.3",
  "dependencies": {
    "@module-federation/runtime": "^0.18.3",
    "@module-federation/sdk": "^0.18.3",
    "@rollup/pluginutils": "^5.1.0",
    "defu": "^6.1.4",
    "estree-walker": "^2",
    "magic-string": "^0.30.11",
    "pathe": "^1.1.2"
  },
  "peerDependencies": {
    "@emotion/cache": "*",
    "@emotion/react": "*",
    "@emotion/styled": "*",
    "@mui/icons-material": "*",
    "@mui/material": "*",
    "@mui/styled-engine": "*",
    "@mui/system": "*",
    "msp_ui_common": "*",
    "react": "*",
    "react-dom": "*"
  },
  "peerDependenciesMeta": {
    "@emotion/cache": {
      "optional": true
    },
    "@emotion/react": {
      "optional": true
    },
    "@emotion/styled": {
      "optional": true
    },
    "@mui/icons-material": {
      "optional": true
    },
    "@mui/material": {
      "optional": true
    },
    "@mui/styled-engine": {
      "optional": true
    },
    "@mui/system": {
      "optional": true
    },
    "msp_ui_common": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "@types/node": "^22.7.4",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "husky": "^8.0.3",
    "microbundle": "^0.15.1",
    "mime-types": "^2.1.35",
    "prettier": "3.3.3",
    "pretty-quick": "^4.0.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.47.1",
    "ts-morph": "^27.0.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.1",
    "wait-on": "^8.0.1"
  }
}
