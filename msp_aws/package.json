{
  "name": "msp_aws",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clear_mf_cache": "rm -rf node_modules/.vite && rm -rf node_modules/__mf__virtual",
    "start": "node ./distApi/serviceActivityElements/server.js --inspect & vite",
    "start:server": "node ./distApi/serviceActivityElements/server.js",
    "data": "node ./distApi/dataActivityElements/server.js --inspect & vite",
    "start:data": "node ./distApi/dataActivityElements/server.js",
    "dev": "vite",
    "build": "yarn clear_mf_cache && tsgo -b && vite build",
    "build:server": "tsgo -b",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@module-federation/vite": "workspace:*",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "msp_common": "workspace:*",
    "msp_svr_common": "workspace:*",
    "msp_ui_common": "workspace:*",
    "node-fetch": "^3.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@types/cookie-parser": "^1",
    "@types/cors": "^2",
    "@types/express": "^5",
    "@types/express-fileupload": "^1",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "happy-dom": "^17.4.7",
    "typescript": "5.9.3",
    "vitest": "^3.1.3"
  },
  "packageManager": "yarn@4.13.0"
}
